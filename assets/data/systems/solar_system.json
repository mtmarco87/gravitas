    "meanAnomalyAtEpoch": "radians",
    "argumentOfPeriapsis": "radians (argument of periapsis: omega)",
    "inclination": "radians",
    "longitudeOfAscendingNode": "radians",
    "spinAxis.rightAscension": "radians (north-pole RA in ICRF/J2000)",
    "spinAxis.declination": "radians (north-pole Dec in ICRF/J2000)",
    "spinAxis.tilt": "radians (tilt from orbital normal)",
    "spinAxis.azimuth": "radians (in orbital plane, measured from projected world +X axis)",
    "spinAxis.initialRotationPhase": "radians (optional authored axial phase at simulation epoch t=0; seeds the body's initial meridian orientation for all spin modes)",
    "spinPhysics.inertiaFactor": "dimensionless (normalized polar moment of inertia, C/(M R^2))",
    "spinPhysics.k2OverQ": "dimensionless (effective equilibrium-tide response coefficient; 0 disables tidal damping)",
    "spinPhysics.preferredLockPhase": "radians (optional preferred face-lock phase offset relative to the parent direction in the orbital plane)"
  },
  "_conventions": {
    "periapsisAngle": "The JSON stores argumentOfPeriapsis = omega. The longitude of periapsis is derived as longitudeOfAscendingNode + argumentOfPeriapsis (varpi = Omega + omega)."
